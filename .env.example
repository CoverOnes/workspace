# Workspace service environment variables
# Copy this file to .env for local development (never commit .env)

# Required: Postgres DSN
WORKSPACE_POSTGRES_DSN=postgres://REPLACE_ME:REPLACE_ME@localhost:5432/workspace?sslmode=disable

# Optional: Postgres schema isolation (default: "" = public schema).
# Set to "workspace" when sharing one Aiven database with other CoverOnes services
# so each service is isolated by schema (search_path) rather than by database.
# Allowed characters: [a-zA-Z0-9_] only.
# WORKSPACE_DB_SCHEMA=workspace

# Optional: Redis URL (leave empty to use noop publisher + in-process rate limiter)
WORKSPACE_REDIS_URL=

# Server port (default: 8082)
WORKSPACE_PORT=8082

# Log level: DEBUG | INFO | WARN | ERROR (default: INFO)
WORKSPACE_LOG_LEVEL=INFO

# Environment: development | production | test (default: development)
WORKSPACE_ENV=development
