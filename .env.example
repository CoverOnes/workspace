# Workspace service environment variables
# Copy this file to .env for local development (never commit .env)

# Required: Postgres DSN
WORKSPACE_POSTGRES_DSN=postgres://REPLACE_ME:REPLACE_ME@localhost:5432/workspace?sslmode=disable

# Optional: Postgres schema isolation (default: "" = public schema).
# Set to "workspace" when sharing one Aiven database with other CoverOnes services
# so each service is isolated by schema (search_path) rather than by database.
# Allowed characters: [a-zA-Z0-9_] only.
# WORKSPACE_DB_SCHEMA=workspace

# Optional: DB connection pool sizing (defaults: max=10, min=2).
# Reduce when sharing a small Aiven plan across many services (e.g. max=2, min=0).
# WORKSPACE_DB_MAX_CONNS=10
# WORKSPACE_DB_MIN_CONNS=2

# Optional: Redis URL (leave empty to use noop publisher + in-process rate limiter)
WORKSPACE_REDIS_URL=

# Server port (default: 8082)
WORKSPACE_PORT=8082

# Log level: DEBUG | INFO | WARN | ERROR (default: INFO)
WORKSPACE_LOG_LEVEL=INFO

# Environment: development | production | test (default: development)
WORKSPACE_ENV=development

# Shared service token for the internal S2S contract-create endpoint
# (POST /internal/v1/contracts). The marketplace service supplies this in the
# X-Service-Token header; it is compared in constant time.
# REQUIRED in production/test (the service will refuse to start without it).
# In development it may be left empty if you are not exercising the S2S endpoint.
# MUST be at least 32 characters of high-entropy randomness.
# Generate one with: openssl rand -base64 48
WORKSPACE_CONTRACT_SERVICE_TOKEN=REPLACE_ME_min32chars

# Gateway-origin identity signature (conventions §24.1 — defense-in-depth)
# MUST equal the gateway's GATEWAY_HMAC_SECRET. ≥32 chars.
# Non-dev (staging/production): REQUIRED — boot fails fast if empty/short.
# Development: may be left empty (verification disabled, mirroring the gateway's
# dev signing-skip). chmod 0600 any file that provides this; env var is canonical.
WORKSPACE_GATEWAY_HMAC_SECRET=REPLACE_ME_min32chars
